<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Silver Platter Data Map, {{ business.name | default("Your Business") }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f8f7f4;
    --ink: #1a1a1a;
    --ink-secondary: #3d3d3d;
    --muted: #6b6b6b;
    --subtle: #9a9a9a;
    --line: #e2e0db;
    --line-light: #eeedea;
    --coral: #E07A4F;
    --coral-dark: #c5623a;
    --coral-soft: rgba(224, 122, 79, 0.10);
    --coral-softer: rgba(224, 122, 79, 0.05);
    --coral-border: rgba(224, 122, 79, 0.28);
    --green: #1f7a4d;
    --green-soft: rgba(31, 122, 77, 0.08);
    --card: #ffffff;
    --card-hover: #fefefe;
    --shadow-xs: 0 1px 2px rgba(0,0,0,0.03);
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.03);
    --shadow-md: 0 2px 8px rgba(0,0,0,0.06), 0 12px 32px rgba(0,0,0,0.06);
    --shadow-lg: 0 4px 12px rgba(0,0,0,0.08), 0 20px 48px rgba(0,0,0,0.08);
    --radius: 8px;
    --radius-lg: 12px;
    --content-max: 1200px;
    --content-pad: 48px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    line-height: 1.6;
    font-size: 14px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ---- Header ---- */
  header {
    background: linear-gradient(180deg, #ffffff 0%, #faf9f6 100%);
    border-bottom: 1px solid var(--line);
    padding: 56px var(--content-pad) 40px;
  }
  header .header-inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }
  .stack-tag {
    display: inline-block;
    font-size: 11px;
    color: var(--coral);
    background: var(--coral-soft);
    border: 1px solid var(--coral-border);
    border-radius: 999px;
    padding: 5px 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
  }
  h1 {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 14px;
    max-width: 840px;
    line-height: 1.2;
    color: var(--ink);
  }
  .lead {
    color: var(--muted);
    font-size: 15px;
    max-width: 720px;
    margin: 0 0 32px;
    line-height: 1.65;
  }
  .hero-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .hero-stat {
    background: var(--card);
    border: 1px solid var(--line-light);
    border-radius: var(--radius);
    padding: 16px 24px;
    min-width: 140px;
    box-shadow: var(--shadow-xs);
  }
  .hero-stat .num {
    font-size: 32px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .hero-stat .label {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 6px;
    font-weight: 500;
  }
  .hero-stat .num.coral { color: var(--coral); }

  /* ---- Tab Nav ---- */
  nav.tabs {
    background: var(--card);
    padding: 0 var(--content-pad);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    gap: 2px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  nav.tabs::-webkit-scrollbar { display: none; }
  nav.tabs .tabs-inner {
    max-width: var(--content-max);
    margin: 0 auto;
    display: flex;
    gap: 2px;
    width: 100%;
  }
  .tab-btn {
    background: none;
    border: none;
    padding: 14px 20px;
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    font-family: inherit;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }
  .tab-btn:hover { color: var(--ink-secondary); }
  .tab-btn.active {
    color: var(--ink);
    border-bottom-color: var(--coral);
    font-weight: 600;
  }

  /* ---- Legend ---- */
  .legend-bar {
    background: rgba(0,0,0,0.02);
    padding: 10px var(--content-pad);
    border-bottom: 1px solid var(--line-light);
    display: flex;
    gap: 24px;
    font-size: 12px;
    color: var(--muted);
    align-items: center;
    flex-wrap: wrap;
  }
  .legend-bar .legend-inner {
    max-width: var(--content-max);
    margin: 0 auto;
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
    width: 100%;
  }
  .legend-item { display: flex; align-items: center; gap: 8px; }
  .legend-swatch {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    border: 1.5px solid var(--ink);
    background: white;
    flex-shrink: 0;
  }
  .legend-swatch.have { color: var(--green); border-color: var(--green); }
  .legend-swatch.opportunity {
    color: white;
    background: var(--coral);
    border-color: var(--coral);
  }

  /* ---- Tab Panels ---- */
  .tab-panel {
    display: none;
    padding: 40px var(--content-pad);
    animation: fadeUp 0.25s ease-out;
  }
  .tab-panel.active { display: block; }
  .tab-panel .panel-inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ---- Lanes (Pantry / Prep / Plate) ---- */
  .lane { margin-bottom: 36px; }
  .lane-banner {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 12px 18px;
    border-left: 4px solid var(--coral);
    background: var(--coral-softer);
    margin-bottom: 20px;
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .lane-banner .lane-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .lane-banner .lane-caption {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.4;
  }
  .lane-row {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 14px;
  }

  /* ---- Cards ---- */
  .card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px 20px;
    box-shadow: var(--shadow-xs);
    cursor: pointer;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s;
    position: relative;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--muted);
  }
  .card.is-highlighted {
    border-color: var(--coral);
    box-shadow: 0 0 0 3px var(--coral-soft), var(--shadow-sm);
  }
  .card .tool {
    font-weight: 600;
    font-size: 15px;
    margin-bottom: 8px;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .card .chip {
    display: inline-block;
    background: rgba(0,0,0,0.04);
    border-radius: 4px;
    padding: 3px 9px;
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--muted);
    margin-right: 4px;
    margin-top: 4px;
    font-weight: 500;
  }
  .card .meta {
    font-size: 12px;
    color: var(--muted);
    margin-top: 10px;
    line-height: 1.5;
  }
  .card .meta strong { color: var(--ink-secondary); font-weight: 600; }
  .card .quick-flag {
    display: inline-block;
    margin-top: 10px;
    padding: 4px 10px;
    background: var(--coral-soft);
    color: var(--coral-dark);
    font-size: 11px;
    border-radius: 4px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .badge {
    position: absolute;
    top: -9px;
    right: -9px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    border: 2px solid white;
    box-shadow: var(--shadow-sm);
    background: white;
  }
  .badge.have { color: var(--green); background: #e8f5ee; }
  .badge.missing { color: var(--muted); background: #f0efec; }
  .badge.opportunity {
    color: white;
    background: var(--coral);
  }

  /* ---- Start-here callout ---- */
  .start-here {
    background: var(--coral-softer);
    border: 1px solid var(--coral-border);
    border-radius: var(--radius);
    padding: 16px 20px;
    margin-bottom: 28px;
    font-size: 13px;
    color: var(--ink-secondary);
    line-height: 1.6;
  }
  .start-here strong { color: var(--coral); }

  /* ---- Recipes ---- */
  .recipes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 20px;
    margin-top: 20px;
  }
  .recipe-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-xs);
    cursor: pointer;
    transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
    position: relative;
    overflow: hidden;
  }
  .recipe-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--coral), var(--coral-dark));
    opacity: 0;
    transition: opacity 0.18s;
  }
  .recipe-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--muted);
  }
  .recipe-card:hover::before { opacity: 1; }
  .recipe-card .time-saved {
    position: absolute;
    top: 18px;
    right: 18px;
    background: var(--coral);
    color: white;
    font-size: 11px;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 999px;
    letter-spacing: 0.02em;
  }
  .recipe-card h3 {
    margin: 0 0 6px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    padding-right: 100px;
    line-height: 1.25;
  }
  .recipe-goal {
    color: var(--muted);
    margin: 0 0 20px;
    font-size: 13px;
    line-height: 1.6;
  }
  .recipe-flow {
    background: rgba(0,0,0,0.02);
    border-radius: var(--radius);
    padding: 12px 14px;
    font-size: 12px;
    color: var(--ink);
    line-height: 1.8;
    margin-bottom: 18px;
  }
  .recipe-flow .ingredient {
    display: inline-block;
    background: white;
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 3px 10px;
    margin: 2px;
    font-weight: 500;
  }
  .recipe-flow .ingredient.outcome {
    background: var(--coral);
    color: white;
    border-color: var(--coral);
    font-weight: 700;
  }
  .recipe-flow .arrow { color: var(--coral); margin: 0 4px; font-weight: 700; }
  .recipe-impact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
    font-size: 12px;
  }
  .recipe-impact .before,
  .recipe-impact .after {
    padding: 10px 14px;
    border-radius: var(--radius);
    line-height: 1.5;
  }
  .recipe-impact .before { background: rgba(0,0,0,0.03); color: var(--muted); }
  .recipe-impact .after {
    background: var(--coral-soft);
    color: var(--ink-secondary);
    border-left: 3px solid var(--coral);
  }
  .recipe-cta {
    display: inline-block;
    color: var(--coral);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: color 0.12s;
  }
  .recipe-card:hover .recipe-cta { color: var(--coral-dark); }

  /* ---- Setup / Build Plan ---- */
  .setup-intro {
    color: var(--muted);
    margin-bottom: 32px;
    max-width: 720px;
    font-size: 14px;
    line-height: 1.7;
  }
  .setup-step {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 28px 32px;
    margin-bottom: 16px;
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: 24px;
    box-shadow: var(--shadow-xs);
    transition: box-shadow 0.18s;
  }
  .setup-step:hover { box-shadow: var(--shadow-sm); }
  .step-num {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--ink);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .setup-step.is-zero {
    border-color: var(--coral-border);
    background: linear-gradient(180deg, var(--coral-softer), white);
  }
  .setup-step.is-zero .step-num { background: var(--coral); }
  .setup-step.is-first .step-num { background: var(--coral); }
  .setup-step h3 {
    margin: 4px 0 10px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .step-pretitle {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    color: var(--coral);
    margin-bottom: 4px;
  }
  .step-block { margin-bottom: 14px; }
  .step-block p {
    margin: 0;
    line-height: 1.65;
    font-size: 14px;
  }
  .step-block-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    color: var(--subtle);
    margin-bottom: 6px;
  }
  .step-requires {
    background: rgba(0,0,0,0.025);
    border-left: 3px solid var(--line);
    padding: 10px 14px;
    margin-bottom: 14px;
    font-size: 13px;
    color: var(--muted);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .step-working {
    background: var(--green-soft);
    border-left: 3px solid var(--green);
    padding: 12px 16px;
    margin-top: 14px;
    font-size: 13px;
    border-radius: 0 var(--radius) var(--radius) 0;
    line-height: 1.55;
  }
  .step-working strong { color: var(--green); }
  .step-install {
    background: #1e1e2e;
    color: #cdd6f4;
    padding: 16px 20px;
    border-radius: var(--radius);
    font-family: 'SF Mono', ui-monospace, Menlo, 'Cascadia Code', monospace;
    font-size: 12px;
    line-height: 1.7;
    overflow-x: auto;
    white-space: pre;
  }
  .step-impact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 14px;
    font-size: 13px;
  }
  .step-impact .before,
  .step-impact .after {
    padding: 12px 16px;
    border-radius: var(--radius);
    line-height: 1.5;
  }
  .step-impact .before { background: rgba(0,0,0,0.03); color: var(--muted); }
  .step-impact .after {
    background: var(--coral-soft);
    border-left: 3px solid var(--coral);
    color: var(--ink-secondary);
  }
  .step-time {
    color: var(--subtle);
    font-size: 12px;
    margin: 14px 0 0;
    font-style: italic;
  }
  .closing-card {
    background: var(--card);
    border: 2px dashed var(--coral-border);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    margin-top: 16px;
    text-align: center;
  }
  .closing-card h3 {
    margin: 0 0 10px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .closing-card p {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
    max-width: 560px;
    margin: 0 auto;
  }
  .closing-card a {
    color: var(--coral);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--coral-border);
    transition: border-color 0.12s;
  }
  .closing-card a:hover { border-color: var(--coral); }

  /* ---- Modal ---- */
  .overlay {
    position: fixed;
    inset: 0;
    background: rgba(26,26,26,0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 24px;
  }
  .overlay.visible { display: flex; }
  .modal {
    background: white;
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 720px;
    max-height: 88vh;
    overflow-y: auto;
    padding: 36px;
    box-shadow: var(--shadow-lg);
    animation: modalIn 0.2s ease-out;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.97) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .modal-large { max-width: 880px; }
  .modal h2 {
    margin: 0 0 6px;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .modal .subtle { color: var(--muted); font-size: 13px; margin-bottom: 24px; }
  .modal-section { margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--line-light); }
  .modal-section:first-of-type { border-top: none; padding-top: 0; }
  .modal-section h3 {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--subtle);
    margin: 0 0 10px;
    font-weight: 700;
  }
  .modal-section p { margin: 0 0 8px; line-height: 1.65; }
  .close-btn {
    background: none;
    border: 1px solid var(--line);
    padding: 8px 18px;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 13px;
    color: var(--muted);
    margin-top: 28px;
    font-family: inherit;
    font-weight: 500;
    transition: color 0.12s, border-color 0.12s;
  }
  .close-btn:hover { color: var(--ink); border-color: var(--ink); }

  /* ---- Connection tabs (inside modal) ---- */
  .conn-tabs {
    display: flex;
    gap: 4px;
    border-bottom: 1px solid var(--line-light);
    margin-bottom: 18px;
  }
  .conn-tab {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 10px 16px;
    font-size: 13px;
    cursor: pointer;
    color: var(--muted);
    font-family: inherit;
    font-weight: 500;
    text-align: left;
    line-height: 1.3;
    transition: color 0.12s;
  }
  .conn-tab small { display: block; font-size: 10px; opacity: 0.7; font-weight: 400; margin-top: 2px; }
  .conn-tab.active { color: var(--ink); border-bottom-color: var(--coral); }
  .conn-tab:hover { color: var(--ink-secondary); }
  .conn-content { display: none; }
  .conn-content.active { display: block; }
  .conn-content p { margin: 0 0 10px; }
  .conn-content ul { margin: 4px 0 12px; padding-left: 20px; }
  .conn-content li { margin-bottom: 4px; line-height: 1.55; }
  .conn-content .conn-summary {
    background: var(--coral-softer);
    border-left: 3px solid var(--coral);
    padding: 12px 16px;
    border-radius: 0 var(--radius) var(--radius) 0;
    margin-bottom: 14px;
    font-size: 13px;
    line-height: 1.55;
  }
  .conn-content code {
    background: rgba(0,0,0,0.04);
    padding: 2px 7px;
    border-radius: 4px;
    font-size: 12px;
    font-family: 'SF Mono', ui-monospace, Menlo, monospace;
  }
  .conn-content pre {
    background: #1e1e2e;
    color: #cdd6f4;
    padding: 14px 18px;
    border-radius: var(--radius);
    font-size: 12px;
    overflow-x: auto;
    margin: 8px 0 14px;
    line-height: 1.6;
  }
  .install-toggle {
    background: none;
    border: 1px solid var(--line);
    padding: 5px 12px;
    border-radius: 5px;
    cursor: pointer;
    font-size: 11px;
    color: var(--muted);
    font-family: inherit;
    font-weight: 500;
    margin-bottom: 8px;
    transition: color 0.12s, border-color 0.12s;
  }
  .install-toggle:hover { color: var(--ink); border-color: var(--ink); }
  .install-block { display: none; }
  .install-block.visible { display: block; }

  /* ---- Sample previews ---- */
  .sample-preview {
    background: rgba(0,0,0,0.025);
    border-left: 3px solid var(--coral);
    padding: 16px 18px;
    border-radius: 0 var(--radius) var(--radius) 0;
    font-family: 'SF Mono', ui-monospace, Menlo, monospace;
    font-size: 12px;
    line-height: 1.6;
    white-space: pre-wrap;
    overflow-x: auto;
    color: var(--ink-secondary);
  }

  /* ---- Ideation list ---- */
  .ideation-list {
    counter-reset: step;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .ideation-list li {
    counter-increment: step;
    padding: 10px 0 10px 40px;
    position: relative;
    font-size: 13px;
    line-height: 1.6;
    border-bottom: 1px dashed var(--line-light);
  }
  .ideation-list li:last-child { border-bottom: none; }
  .ideation-list li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 10px;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--coral-soft);
    color: var(--coral);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
  }
  .ideation-list .actor {
    display: inline-block;
    background: var(--ink);
    color: white;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    margin-right: 8px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ---- Stack pills ---- */
  .stack-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .stack-pill {
    background: var(--coral-soft);
    color: var(--coral-dark);
    border: 1px solid var(--coral-border);
    border-radius: 5px;
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 500;
  }
  .stack-pill.skill { background: rgba(0,90,180,0.07); color: #0a3a78; border-color: rgba(0,90,180,0.18); }
  .stack-pill.subagent { background: rgba(120,40,160,0.07); color: #501a78; border-color: rgba(120,40,160,0.18); }
  .stack-pill.hook { background: rgba(180,90,0,0.07); color: #6a3500; border-color: rgba(180,90,0,0.18); }
  .stack-pill.rule { background: rgba(0,128,80,0.07); color: #15543a; border-color: rgba(0,128,80,0.18); }
  .primitive-key {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px 16px;
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 16px;
    padding: 14px;
    background: rgba(0,0,0,0.02);
    border-radius: var(--radius);
  }
  .primitive-key div { display: flex; gap: 6px; align-items: center; }
  .primitive-key .pk-label { font-weight: 600; color: var(--ink); }

  /* ---- Today / Monday comparison cards ---- */
  .today-card {
    background: rgba(0,0,0,0.025);
    border-radius: var(--radius);
    padding: 16px 18px;
    margin-bottom: 18px;
    font-size: 13px;
    line-height: 1.6;
  }
  .today-card .today-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--subtle);
    font-weight: 700;
    margin-bottom: 6px;
  }
  .monday-card {
    background: var(--coral-softer);
    border-left: 3px solid var(--coral);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 16px 18px;
    margin-bottom: 18px;
    font-size: 13px;
    line-height: 1.6;
  }
  .monday-card .monday-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--coral);
    font-weight: 700;
    margin-bottom: 6px;
  }

  /* ---- Sankey ---- */
  .sankey-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 20px;
    font-size: 12px;
    color: var(--muted);
  }
  .sankey-legend-col { display: flex; align-items: center; gap: 8px; }
  .sankey-legend-dot {
    width: 14px;
    height: 14px;
    border-radius: 4px;
    display: inline-block;
  }
  .pantry-dot { background: #4a5d7e; }
  .prep-dot { background: #6b8e6b; }
  .plate-dot { background: #1a1a1a; }
  .interact-dot { background: #8a6db6; }
  .opp-dot { background: var(--coral); }
  .sankey-wrap {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-xs);
    overflow-x: auto;
  }
  #sankey-svg {
    width: 100%;
    height: auto;
    min-width: 800px;
    max-height: 720px;
  }
  .sankey-node-rect {
    cursor: pointer;
    transition: filter 0.15s, opacity 0.15s;
  }
  .sankey-node-rect:hover { filter: brightness(1.1); }
  .sankey-node-label {
    font-size: 12px;
    font-weight: 600;
    fill: var(--ink);
    pointer-events: none;
  }
  .sankey-node-sub {
    font-size: 10.5px;
    fill: var(--muted);
    pointer-events: none;
  }
  .sankey-link {
    fill: none;
    stroke: #c5c3be;
    stroke-opacity: 0.3;
    transition: stroke-opacity 0.15s, stroke 0.15s;
    cursor: pointer;
  }
  .sankey-link.is-opportunity { stroke: var(--coral); stroke-opacity: 0.45; }
  .sankey-link:hover, .sankey-link.is-active {
    stroke-opacity: 0.85;
    stroke: var(--coral);
  }
  .sankey-help {
    color: var(--subtle);
    font-size: 12px;
    margin-top: 16px;
    font-style: italic;
    line-height: 1.5;
  }

  /* ---- Footer ---- */
  footer.page-footer {
    margin-top: 60px;
    padding: 28px var(--content-pad);
    color: var(--subtle);
    font-size: 12px;
    border-top: 1px solid var(--line-light);
    text-align: center;
    line-height: 1.5;
  }
  footer.page-footer code {
    background: rgba(0,0,0,0.04);
    padding: 2px 7px;
    border-radius: 4px;
    font-family: 'SF Mono', ui-monospace, Menlo, monospace;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    :root { --content-pad: 32px; }
    header { padding: 40px var(--content-pad) 32px; }
    h1 { font-size: 26px; }
    .hero-stat { min-width: 120px; padding: 14px 18px; }
    .hero-stat .num { font-size: 28px; }
    .recipes-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    :root { --content-pad: 20px; }
    header { padding: 32px var(--content-pad) 28px; }
    h1 { font-size: 22px; }
    .lead { font-size: 14px; }
    .hero-strip { gap: 8px; }
    .hero-stat { min-width: 0; flex: 1 1 calc(50% - 4px); padding: 12px 14px; }
    .hero-stat .num { font-size: 24px; }
    .hero-stat .label { font-size: 10px; }
    .tab-btn { padding: 12px 14px; font-size: 12px; }
    .lane-banner { flex-direction: column; gap: 4px; }
    .lane-row { grid-template-columns: 1fr; }
    .card { padding: 16px; }
    .card .tool { font-size: 14px; }
    .recipe-card { padding: 22px; }
    .recipe-card h3 { font-size: 16px; padding-right: 80px; }
    .recipe-card .time-saved { font-size: 10px; padding: 4px 10px; top: 14px; right: 14px; }
    .recipe-impact { grid-template-columns: 1fr; }
    .setup-step { grid-template-columns: 40px 1fr; gap: 16px; padding: 20px; }
    .step-num { width: 40px; height: 40px; font-size: 16px; }
    .setup-step h3 { font-size: 16px; }
    .step-impact { grid-template-columns: 1fr; }
    .modal { padding: 24px; max-width: 100%; }
    .modal h2 { font-size: 20px; }
    .legend-bar { gap: 14px; }
    .sankey-wrap { padding: 16px; }
  }

  @media (max-width: 480px) {
    :root { --content-pad: 16px; }
    h1 { font-size: 20px; }
    .hero-stat { flex: 1 1 100%; }
    .tab-btn { padding: 10px 10px; font-size: 11px; }
    .legend-bar { flex-direction: column; align-items: flex-start; gap: 8px; }
    .primitive-key { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

{# Pre-compute hero numbers #}
{% set tools_count = pantry | length %}
{% set briefs_count = (prep | selectattr('status', 'equalto', 'have') | list | length) + (plate | selectattr('status', 'equalto', 'have') | list | length) %}
{% set quick_wins = opportunities | length %}

<header>
  <div class="header-inner">
    {% if business.stack_summary %}
    <div class="stack-tag">{{ business.stack_summary }}</div>
    {% endif %}
    <h1>{{ business.headline | default(business.name + ", here's how your tools talk to each other today and what to fix first.") }}</h1>
    <p class="lead">{{ business.lead | default("Three sections below. Pantry = your raw data. Prep table = the weekly briefs Claude assembles. Plate = the decisions you actually serve up. Click any card or recipe for plain English.") }}</p>
    <div class="hero-strip">
      <div class="hero-stat">
        <div class="num">{{ tools_count }}</div>
        <div class="label">Tools mapped</div>
      </div>
      <div class="hero-stat">
        <div class="num">{{ recipes | length }}</div>
        <div class="label">Recipes ready</div>
      </div>
      <div class="hero-stat">
        <div class="num coral">{{ quick_wins }}</div>
        <div class="label">Quick wins</div>
      </div>
      {% if business.hours_back_per_week %}
      <div class="hero-stat">
        <div class="num coral">{{ business.hours_back_per_week }}</div>
        <div class="label">Hours/week back</div>
      </div>
      {% endif %}
    </div>
  </div>
</header>

<nav class="tabs">
  <div class="tabs-inner">
    <button class="tab-btn active" data-tab="map">What you have today</button>
    <button class="tab-btn" data-tab="flow">Data flow</button>
    <button class="tab-btn" data-tab="recipes">What we'll build ({{ recipes | length }})</button>
    <button class="tab-btn" data-tab="setup">Your 30-day build plan</button>
  </div>
</nav>

<div class="legend-bar">
  <div class="legend-inner">
    <span style="font-weight:600;color:var(--ink);font-size:11px;text-transform:uppercase;letter-spacing:0.08em;">Legend</span>
    <div class="legend-item"><span class="legend-swatch have">&check;</span> You've got it</div>
    <div class="legend-item"><span class="legend-swatch">?</span> Missing or not set up yet</div>
    <div class="legend-item"><span class="legend-swatch opportunity">!</span> Quick win, money or hours on the table</div>
  </div>
</div>

<section id="tab-map" class="tab-panel active">
  <div class="panel-inner">

  {% if quick_wins %}
  <div class="start-here">
    <strong>Where to start:</strong> click any card with the orange <span style="background:var(--coral);color:white;padding:2px 8px;border-radius:50%;font-size:10px;font-weight:700;">!</span> badge first. Those are the {{ quick_wins }} unlocks where Claude can earn its keep.
  </div>
  {% endif %}

  <div class="lane" data-lane="pantry">
    <div class="lane-banner">
      <div class="lane-title">Pantry</div>
      <div class="lane-caption">Your raw ingredients, the tools your data already lives in.</div>
    </div>
    <div class="lane-row">
      {% for item in pantry %}
      {% set opps = opp_by_id.get(item.id, []) %}
      {% set badge_class = 'opportunity' if opps else ('have' if item.status == 'have' else 'missing') %}
      {% set badge_char = '!' if opps else ('&check;' if item.status == 'have' else '?') %}
      <div class="card" data-card-id="{{ item.id }}" data-lane="pantry">
        <div class="badge {{ badge_class }}">{{ badge_char | safe }}</div>
        <div class="tool">{{ item.tool }}</div>
        <span class="chip">{{ item.format }}</span>
        <span class="chip">{{ item.cadence }}</span>
        <div class="meta">{{ item.volume_friendly | default(item.volume + ' volume') }}</div>
        {% if item.paying_unused %}
        <div class="quick-flag">Already paying for this, not yet using</div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="lane" data-lane="prep">
    <div class="lane-banner">
      <div class="lane-title">Prep Table</div>
      <div class="lane-caption">Where the night's mise-en-place gets done, weekly summaries Claude writes for you.</div>
    </div>
    <div class="lane-row">
      {% for item in prep %}
      {% set opps = opp_by_id.get(item.id, []) %}
      {% set badge_class = 'opportunity' if (opps or item.status == 'missing') else 'have' %}
      {% set badge_char = '!' if (opps or item.status == 'missing') else '&check;' %}
      {% set source_names = [] %}
      {% for sid in item.sources %}
        {% set src = (pantry | selectattr('id', 'equalto', sid) | list) %}
        {% if src %}{% set _ = source_names.append(src[0].tool) %}{% endif %}
      {% endfor %}
      <div class="card" data-card-id="{{ item.id }}" data-lane="prep">
        <div class="badge {{ badge_class }}">{{ badge_char | safe }}</div>
        <div class="tool">{{ item.display_name | default(item.name) }}</div>
        <span class="chip">{{ item.domain_friendly | default(item.domain) }}</span>
        {% if item.schedule %}<span class="chip">{{ item.schedule }}</span>{% endif %}
        <div class="meta">
          <strong>In:</strong> {{ source_names | join(', ') if source_names else 'none yet' }}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="lane" data-lane="plate">
    <div class="lane-banner">
      <div class="lane-title">Plate</div>
      <div class="lane-caption">What gets served to a human, the briefs and drafts you actually act on.</div>
    </div>
    <div class="lane-row">
      {% for item in plate %}
      {% set opps = opp_by_id.get(item.id, []) %}
      {% set badge_class = 'opportunity' if (opps or item.status == 'missing') else 'have' %}
      {% set badge_char = '!' if (opps or item.status == 'missing') else '&check;' %}
      <div class="card" data-card-id="{{ item.id }}" data-lane="plate">
        <div class="badge {{ badge_class }}">{{ badge_char | safe }}</div>
        <div class="tool">{{ item.name }}</div>
        <span class="chip">Written by {{ item.agent_friendly | default(item.agent) }}</span>
        {% if item.consumers %}<span class="chip">For: {{ item.consumers | join(', ') }}</span>{% endif %}
        <div class="meta">&#128274; {{ item.approval_friendly | default('You sign off before send') }}</div>
      </div>
      {% endfor %}
    </div>
  </div>

  </div>
</section>

<section id="tab-flow" class="tab-panel">
  <div class="panel-inner">
  <p class="setup-intro">The mental model in one picture. Your data moves left to right: <strong>raw sources</strong> feed <strong>weekly silver platters</strong>, platters feed the <strong>briefs and drafts</strong> Claude writes for you, and those land in the <strong>channels you actually use</strong> (Slack, your inbox, your iPad). The AI layer sits on top of the data prep, never the other way around. Hover any line to trace it. Click a node to open the details.</p>

  <div class="sankey-legend">
    <div class="sankey-legend-col"><span class="sankey-legend-dot pantry-dot"></span> Pantry (raw data)</div>
    <div class="sankey-legend-col"><span class="sankey-legend-dot prep-dot"></span> Prep (silver platters)</div>
    <div class="sankey-legend-col"><span class="sankey-legend-dot plate-dot"></span> Plate (briefs you read)</div>
    <div class="sankey-legend-col"><span class="sankey-legend-dot interact-dot"></span> Where you read it</div>
    <div class="sankey-legend-col"><span class="sankey-legend-dot opp-dot"></span> Opportunity / suggested</div>
  </div>

  <div class="sankey-wrap">
    <svg id="sankey-svg" viewBox="0 0 1500 760" preserveAspectRatio="xMidYMid meet"></svg>
  </div>

  <p class="sankey-help">If a Pantry box has no line leaving it, that data is sitting unused. Those are usually the loudest quick wins. Dashed boxes on the right are channels we suggest adding.</p>
  </div>
</section>

<section id="tab-recipes" class="tab-panel">
  <div class="panel-inner">
  <p class="setup-intro">{{ recipes_intro | default(business.name + ", these are the briefs and drafts your team can stop building manually. Each one shows the ingredients, the time saved, and the back-and-forth Claude does on your behalf.") }}</p>

  <div class="recipes-grid">
    {% for r in recipes %}
    <article class="recipe-card" data-recipe-id="{{ r.id }}">
      {% if r.time_saved_per_week %}
      <span class="time-saved">{{ r.time_saved_per_week }}</span>
      {% endif %}
      <h3>{{ r.headline | default(r.name) }}</h3>
      <p class="recipe-goal">{{ r.goal }}</p>
      <div class="recipe-flow">
        {%- set flow = r.ingredients_friendly | default(r.ingredients) -%}
        {%- for ing in flow -%}
          {%- set is_last = loop.last -%}
          <span class="ingredient{% if is_last %} outcome{% endif %}">{{ ing }}</span>{% if not is_last %} <span class="arrow">&rarr;</span> {% endif %}
        {%- endfor -%}
      </div>
      <div class="recipe-impact">
        <div class="before"><strong>Before:</strong> {{ r.before_claude_code }}</div>
        <div class="after"><strong>After:</strong> {{ r.after_claude_code }}</div>
      </div>
      <span class="recipe-cta">Click for the full walkthrough &rarr;</span>
    </article>
    {% endfor %}
  </div>
  </div>
</section>

<section id="tab-setup" class="tab-panel">
  <div class="panel-inner">
  <p class="setup-intro">{{ business.name }}, here's the order to build this in. Each step builds on the last, total: {{ setup_total_time | default("a focused weekend or two evenings") }}. If a step looks like a cliff, hand it to <code>@claude-code-guide</code>.</p>

  <ol class="setup-steps" style="list-style: none; padding: 0;">
    {# Step 0: install Claude Code if not already done #}
    <li class="setup-step is-zero">
      <div class="step-num">0</div>
      <div>
        <div class="step-pretitle">Pre-step (skip if you already have Claude Code)</div>
        <h3>Get Claude Code on your machine</h3>
        <div class="step-block">
          <div class="step-block-label">What</div>
          <p>Install the Claude Code CLI. It's the tool that runs everything below. If you've never opened Terminal, that's fine, this is the only command-line moment until you're set up.</p>
        </div>
        <div class="step-block">
          <div class="step-block-label">Install</div>
          <pre class="step-install">npm install -g @anthropic-ai/claude-code
claude --version  # should print a version number</pre>
        </div>
        <div class="step-working">
          <strong>You'll know it's working when:</strong> typing <code>claude --version</code> in Terminal prints a version number instead of an error.
        </div>
        <p class="step-time">Setup time: 5 minutes.</p>
      </div>
    </li>

    {% for step in setup_priority %}
    <li class="setup-step{% if loop.first %} is-first{% endif %}">
      <div class="step-num">{{ step.step }}</div>
      <div>
        <h3>{{ step.title_friendly | default(step.title) }}</h3>

        {% if step.requires %}
        <div class="step-requires"><strong>Requires:</strong> {{ step.requires }}</div>
        {% endif %}

        <div class="step-block">
          <div class="step-block-label">What</div>
          <p>{{ step.what_to_do }}</p>
        </div>

        <div class="step-block">
          <div class="step-block-label">Why this first</div>
          <p>{{ step.why }}</p>
        </div>

        {% if step.install %}
        <div class="step-block">
          <div class="step-block-label">Install</div>
          <pre class="step-install">{{ step.install }}</pre>
        </div>
        {% endif %}

        <div class="step-impact">
          <div class="before"><strong>Before:</strong> {{ step.before }}</div>
          <div class="after"><strong>After:</strong> {{ step.after }}</div>
        </div>

        {% if step.working_when %}
        <div class="step-working">
          <strong>You'll know it's working when:</strong> {{ step.working_when }}
        </div>
        {% endif %}

        <p class="step-time">Setup time: {{ step.setup_time }}</p>
      </div>
    </li>
    {% endfor %}

    <li class="closing-card">
      <h3>You've shipped your back-of-house.</h3>
      <p>Next: hand <code>@claude-code-guide</code> a one-line ask for your next skill, or join <a href="https://www.skool.com/earlyaidopters/about" target="_blank">the community</a> to see how other operators evolved theirs.</p>
    </li>
  </ol>
  </div>
</section>

<div class="overlay" id="card-modal" onclick="if(event.target.id==='card-modal') closeAll()">
  <div class="modal">
    <h2 id="cm-title"></h2>
    <div class="subtle" id="cm-subtitle"></div>
    <div id="cm-body"></div>
    <button class="close-btn" onclick="closeAll()">Close</button>
  </div>
</div>

<div class="overlay" id="recipe-modal" onclick="if(event.target.id==='recipe-modal') closeAll()">
  <div class="modal modal-large">
    <h2 id="rm-title"></h2>
    <div class="subtle" id="rm-goal"></div>
    <div id="rm-body"></div>
    <button class="close-btn" onclick="closeAll()">Close</button>
  </div>
</div>

<footer class="page-footer">
  Generated by <code>/silver-platter</code> &middot; Click any card or recipe for plain-English details
</footer>

<script>
  const DATA = {
    pantry: {{ pantry | tojson }},
    prep: {{ prep | tojson }},
    plate: {{ plate | tojson }},
    recipes: {{ recipes | tojson }},
    opp_by_id: {{ opp_by_id | tojson }},
    interaction: {{ interaction_layer | tojson }}
  };

  const CONN_FRIENDLY = {
    mcp: { label: 'Easiest setup', summary: 'A pre-built bridge. You add a few lines to a config file once and Claude can ask the tool questions live.' },
    cli: { label: 'If you live in the terminal', summary: 'A command-line wrapper. Best when your developer is comfortable in Terminal and wants speed.' },
    api: { label: 'Custom build', summary: 'Direct API calls. Most flexibility, most code. Use when nothing else fits.' }
  };

  const PRIMITIVE_KEY = `
    <div class="primitive-key">
      <div><span class="stack-pill skill">skill</span><span>= a reusable mini-tool</span></div>
      <div><span class="stack-pill subagent">subagent</span><span>= a specialist staffer</span></div>
      <div><span class="stack-pill hook">hook</span><span>= an auto-trigger</span></div>
      <div><span class="stack-pill rule">rule</span><span>= guardrails Claude follows</span></div>
    </div>`;

  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
      if (btn.dataset.tab === 'flow') renderSankey();
    });
  });

  // ---------- Sankey ----------
  function renderSankey() {
    const svg = document.getElementById('sankey-svg');
    if (!svg || svg.dataset.rendered === '1') return;

    const hasInteract = (DATA.interaction || []).length > 0;
    const W = hasInteract ? 1500 : 1200;
    const H = hasInteract ? 760 : 700;
    const colX = hasInteract
      ? { pantry: 60, prep: 460, plate: 860, interaction: 1260 }
      : { pantry: 80, prep: 540, plate: 1000 };
    const colW = 160;
    const padTop = 44, padBot = 40;
    const usableH = H - padTop - padBot;
    const NODE_GAP = 8;
    const ribbonStrokeMin = 6;

    svg.setAttribute('viewBox', `0 0 ${W} ${H}`);

    const nodes = {};

    function isOpp(item, lane) {
      const opps = DATA.opp_by_id[item.id] || [];
      if (opps.length) return true;
      if (lane !== 'pantry' && item.status === 'missing') return true;
      if (lane === 'interaction' && item.status === 'could-add') return true;
      return false;
    }
    function nodeFill(item, lane) {
      if (lane === 'interaction' && item.status === 'could-add') return '#E07A4F';
      if (isOpp(item, lane)) return '#E07A4F';
      if (lane === 'pantry') return '#4a5d7e';
      if (lane === 'prep')   return '#6b8e6b';
      if (lane === 'interaction') return '#8a6db6';
      return '#1a1a1a';
    }

    // Build link list (pantry->prep, prep->plate, plate->interaction)
    const links = [];
    DATA.prep.forEach(p => {
      (p.sources || []).forEach(sid => {
        if (DATA.pantry.find(x => x.id === sid)) {
          links.push({ from: sid, to: p.id, opp: isOpp(p, 'prep') });
        }
      });
    });
    DATA.plate.forEach(pl => {
      (pl.reads_from || []).forEach(pid => {
        if (DATA.prep.find(x => x.id === pid)) {
          links.push({ from: pid, to: pl.id, opp: isOpp(pl, 'plate') });
        }
      });
    });
    if (hasInteract) {
      DATA.interaction.forEach(ix => {
        (ix.consumes || []).forEach(pid => {
          if (DATA.plate.find(x => x.id === pid)) {
            links.push({ from: pid, to: ix.id, opp: ix.status === 'could-add' });
          }
        });
      });
    }

    // Weight per node = max(1, links touching it)
    const weights = {};
    function bumpW(id) { weights[id] = (weights[id] || 0) + 1; }
    DATA.pantry.forEach(p => weights[p.id] = 0);
    DATA.prep.forEach(p => weights[p.id] = 0);
    DATA.plate.forEach(p => weights[p.id] = 0);
    if (hasInteract) DATA.interaction.forEach(p => weights[p.id] = 0);
    links.forEach(l => { bumpW(l.from); bumpW(l.to); });
    Object.keys(weights).forEach(k => { if (!weights[k]) weights[k] = 1; });

    // Layout each column
    function layoutCol(lane, items) {
      const totalW = items.reduce((s, x) => s + weights[x.id], 0);
      const totalGaps = (items.length - 1) * NODE_GAP;
      const scale = (usableH - totalGaps) / Math.max(1, totalW);
      let y = padTop;
      items.forEach(it => {
        const h = Math.max(28, weights[it.id] * scale);
        nodes[it.id] = {
          id: it.id,
          lane,
          item: it,
          x: colX[lane],
          y,
          w: colW,
          h,
          fill: nodeFill(it, lane),
          opp: isOpp(it, lane),
          // running pointers for ribbon stacking
          outY: y,
          inY: y,
        };
        y += h + NODE_GAP;
      });
    }
    layoutCol('pantry', DATA.pantry);
    layoutCol('prep',   DATA.prep);
    layoutCol('plate',  DATA.plate);
    if (hasInteract) layoutCol('interaction', DATA.interaction);

    // Ribbon thickness = source/target node height divided by their link count, but clamped
    const outCounts = {}, inCounts = {};
    DATA.pantry.forEach(p => outCounts[p.id] = 0);
    DATA.prep.forEach(p => { outCounts[p.id] = 0; inCounts[p.id] = 0; });
    DATA.plate.forEach(p => { outCounts[p.id] = 0; inCounts[p.id] = 0; });
    if (hasInteract) DATA.interaction.forEach(p => inCounts[p.id] = 0);
    links.forEach(l => { outCounts[l.from] = (outCounts[l.from] || 0) + 1; inCounts[l.to] = (inCounts[l.to] || 0) + 1; });

    function ribbonThickness(linkId, fromId, toId) {
      const sNode = nodes[fromId], tNode = nodes[toId];
      const sT = sNode.h / Math.max(1, outCounts[fromId]);
      const tT = tNode.h / Math.max(1, inCounts[toId]);
      return Math.max(ribbonStrokeMin, Math.min(sT, tT));
    }

    // Build SVG markup
    let parts = [];

    // Column headers + sub-captions
    function colHeader(x, label, sub) {
      parts.push(`<text x="${x + colW/2}" y="22" text-anchor="middle" style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;fill:#1a1a1a;font-family:Inter,system-ui,sans-serif;">${label}</text>`);
      parts.push(`<text x="${x + colW/2}" y="36" text-anchor="middle" style="font-size:10px;fill:#6b6b6b;font-family:Inter,system-ui,sans-serif;">${sub}</text>`);
    }
    colHeader(colX.pantry, 'Pantry', 'raw data');
    colHeader(colX.prep,   'Prep table', 'silver platters');
    colHeader(colX.plate,  'Plate', 'briefs you read');
    if (hasInteract) colHeader(colX.interaction, 'Where you read it', 'Slack / inbox / iPad');

    // Ribbons (drawn first so nodes sit on top)
    const linkPaths = [];
    links.forEach((l, i) => {
      const s = nodes[l.from], t = nodes[l.to];
      const thick = ribbonThickness(i, l.from, l.to);
      const sy = s.outY + thick / 2;
      const ty = t.inY + thick / 2;
      s.outY += thick;
      t.inY += thick;
      const x1 = s.x + s.w;
      const x2 = t.x;
      const cx1 = x1 + (x2 - x1) * 0.45;
      const cx2 = x1 + (x2 - x1) * 0.55;
      const path = `M ${x1} ${sy} C ${cx1} ${sy}, ${cx2} ${ty}, ${x2} ${ty}`;
      const cls = l.opp ? 'sankey-link is-opportunity' : 'sankey-link';
      linkPaths.push(`<path class="${cls}" d="${path}" stroke-width="${thick}" data-from="${l.from}" data-to="${l.to}"></path>`);
    });
    parts.push(linkPaths.join(''));

    // Nodes
    function escapeText(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function truncate(s, n) { s = String(s || ''); return s.length > n ? s.slice(0, n - 1) + '…' : s; }

    Object.values(nodes).forEach(n => {
      const labelMain = n.lane === 'pantry'
        ? n.item.tool
        : n.lane === 'interaction'
          ? n.item.channel
          : (n.item.display_name || n.item.name || n.item.tool);
      const labelSub = n.lane === 'pantry'
        ? (n.item.format || '')
        : n.lane === 'prep'
          ? (n.item.domain_friendly || n.item.domain || '')
          : n.lane === 'interaction'
            ? (n.item.status === 'could-add' ? 'suggested add' : (n.item.type || ''))
            : (n.item.agent_friendly || n.item.agent || '');
      const labelOnLeft = (n.lane === 'plate' || n.lane === 'interaction');
      const labelX = labelOnLeft ? n.x - 8 : n.x + n.w + 8;
      const anchor = labelOnLeft ? 'end' : 'start';
      const isSuggested = n.lane === 'interaction' && n.item.status === 'could-add';
      const rectStyle = isSuggested ? 'stroke-dasharray:4 3;stroke:#E07A4F;stroke-width:2;fill:white;' : '';
      const textFill = isSuggested ? 'fill:#E07A4F;' : '';
      const rectFill = isSuggested ? 'white' : n.fill;
      parts.push(
        `<g class="sankey-node" data-card-id="${n.id}" data-lane="${n.lane}" style="cursor:pointer;">` +
        `<rect class="sankey-node-rect" x="${n.x}" y="${n.y}" width="${n.w}" height="${n.h}" rx="4" fill="${rectFill}" style="${rectStyle}" data-card-id="${n.id}" data-lane="${n.lane}"></rect>` +
        `<text class="sankey-node-label" x="${labelX}" y="${n.y + n.h/2 - 2}" text-anchor="${anchor}" dominant-baseline="middle" style="${textFill}font-family:Inter,system-ui,sans-serif;">${escapeText(truncate(labelMain, 32))}</text>` +
        (labelSub ? `<text class="sankey-node-sub" x="${labelX}" y="${n.y + n.h/2 + 12}" text-anchor="${anchor}" dominant-baseline="middle" style="font-family:Inter,system-ui,sans-serif;">${escapeText(truncate(labelSub, 32))}</text>` : '') +
        `</g>`
      );
    });

    svg.innerHTML = parts.join('');
    svg.dataset.rendered = '1';

    // Click handlers, opens the same card modal
    svg.querySelectorAll('.sankey-node').forEach(g => {
      g.addEventListener('click', () => openCardModal(g.dataset.cardId, g.dataset.lane));
    });

    // Hover highlighting, dim siblings
    svg.querySelectorAll('.sankey-link').forEach(p => {
      p.addEventListener('mouseenter', () => {
        svg.querySelectorAll('.sankey-link').forEach(x => x.classList.remove('is-active'));
        p.classList.add('is-active');
      });
      p.addEventListener('mouseleave', () => p.classList.remove('is-active'));
    });
    svg.querySelectorAll('.sankey-node').forEach(g => {
      g.addEventListener('mouseenter', () => {
        const id = g.dataset.cardId;
        svg.querySelectorAll('.sankey-link').forEach(x => {
          const match = x.getAttribute('data-from') === id || x.getAttribute('data-to') === id;
          x.classList.toggle('is-active', match);
        });
      });
      g.addEventListener('mouseleave', () => svg.querySelectorAll('.sankey-link').forEach(x => x.classList.remove('is-active')));
    });
  }
  // -------- end Sankey --------

  document.querySelectorAll('.card').forEach(c => {
    c.addEventListener('click', () => openCardModal(c.dataset.cardId, c.dataset.lane));
  });

  document.querySelectorAll('.recipe-card').forEach(r => {
    r.addEventListener('click', () => openRecipeModal(r.dataset.recipeId));
  });

  function findItem(lane, id) {
    return DATA[lane].find(x => x.id === id);
  }

  function escapeHtml(s) {
    if (s == null) return '';
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function openCardModal(id, lane) {
    if (lane === 'interaction') {
      const ix = (DATA.interaction || []).find(x => x.id === id);
      if (!ix) return;
      document.getElementById('cm-title').textContent = ix.channel;
      document.getElementById('cm-subtitle').textContent =
        ix.status === 'could-add' ? 'Suggested add-on, not yet wired' : 'Already in use';
      let body = `<div class="modal-section"><h3>What this is</h3><p>${escapeHtml(ix.description)}</p></div>`;
      const consumes = (ix.consumes || []).map(pid => {
        const pl = DATA.plate.find(x => x.id === pid);
        return pl ? pl.name : pid;
      });
      if (consumes.length) {
        body += `<div class="modal-section"><h3>Carries which briefs</h3><p>${consumes.map(n => '<code>' + escapeHtml(n) + '</code>').join(' &nbsp;&middot;&nbsp; ')}</p></div>`;
      }
      if (ix.status === 'could-add') {
        body += `<div class="modal-section"><h3>Why suggest this</h3><p>${escapeHtml(ix.description)}</p></div>`;
      }
      document.getElementById('cm-body').innerHTML = body;
      document.getElementById('card-modal').classList.add('visible');
      return;
    }
    const item = findItem(lane, id);
    if (!item) return;
    const opps = (DATA.opp_by_id[id] || []);

    document.getElementById('cm-title').textContent = item.tool || item.display_name || item.name;

    const subtitle =
      lane === 'pantry'
        ? (item.subtitle_friendly || `${item.volume_friendly || (item.volume + ' volume')} · updates ${item.cadence}`)
        : lane === 'prep'
          ? (item.subtitle_friendly || `A ${item.domain_friendly || item.domain} brief Claude writes ${item.schedule || ''}`)
          : (item.subtitle_friendly || `Written by ${item.agent_friendly || item.agent || 'an assistant'} for ${(item.consumers || []).join(', ') || 'you'}`);
    document.getElementById('cm-subtitle').textContent = subtitle;

    let body = '';

    if (item.explanation) {
      body += `<div class="modal-section"><h3>What this is</h3><p>${escapeHtml(item.explanation)}</p></div>`;
    }

    if (lane === 'pantry' && item.connection_methods && item.connection_methods.length) {
      body += `<div class="modal-section"><h3>How to connect this to Claude</h3>`;
      body += `<div class="conn-tabs">`;
      item.connection_methods.forEach((cm, i) => {
        const friendly = CONN_FRIENDLY[cm.type] || { label: cm.type.toUpperCase() };
        body += `<button class="conn-tab ${i===0?'active':''}" data-conn="${cm.type}">${friendly.label}<small>${cm.type.toUpperCase()}</small></button>`;
      });
      body += `</div>`;
      item.connection_methods.forEach((cm, i) => {
        const friendly = CONN_FRIENDLY[cm.type] || { summary: '' };
        body += `<div class="conn-content ${i===0?'active':''}" data-conn-content="${cm.type}">`;
        if (friendly.summary) {
          body += `<div class="conn-summary">${escapeHtml(friendly.summary)}</div>`;
        }
        body += `<p><strong>${escapeHtml(cm.name)}</strong></p>`;
        if (cm.when_to_use) body += `<p>${escapeHtml(cm.when_to_use)}</p>`;
        if (cm.pros && cm.pros.length) {
          body += `<p style="margin-top:8px;"><strong>Pros:</strong></p><ul>` + cm.pros.map(x => `<li>${escapeHtml(x)}</li>`).join('') + `</ul>`;
        }
        if (cm.cons && cm.cons.length) {
          body += `<p><strong>Tradeoffs:</strong></p><ul>` + cm.cons.map(x => `<li>${escapeHtml(x)}</li>`).join('') + `</ul>`;
        }
        if (cm.install || cm.example) {
          const tid = `inst-${id}-${cm.type}`;
          body += `<button class="install-toggle" onclick="document.getElementById('${tid}').classList.toggle('visible')">Show install steps ▾</button>`;
          body += `<div class="install-block" id="${tid}">`;
          if (cm.install) body += `<p style="font-size:12px;color:var(--muted);">Install:</p><pre>${escapeHtml(cm.install)}</pre>`;
          if (cm.example) body += `<p style="font-size:12px;color:var(--muted);">Example:</p><pre>${escapeHtml(cm.example)}</pre>`;
          body += `</div>`;
        }
        body += `</div>`;
      });
      body += `</div>`;
    }

    if (lane === 'pantry') {
      const downstream_prep = DATA.prep.filter(p => (p.sources || []).includes(id));
      const downstream_plate_ids = new Set();
      downstream_prep.forEach(p => DATA.plate.filter(pl => (pl.reads_from || []).includes(p.id)).forEach(pl => downstream_plate_ids.add(pl.id)));
      const downstream_plates = DATA.plate.filter(pl => downstream_plate_ids.has(pl.id));
      if (downstream_prep.length || downstream_plates.length) {
        body += `<div class="modal-section"><h3>Where this data ends up</h3>`;
        if (downstream_prep.length) body += `<p><strong>Feeds into:</strong> ${downstream_prep.map(p => '<code>' + escapeHtml(p.display_name || p.name) + '</code>').join(' · ')}</p>`;
        if (downstream_plates.length) body += `<p><strong>Shows up in:</strong> ${downstream_plates.map(p => '<code>' + escapeHtml(p.name) + '</code>').join(' · ')}</p>`;
        body += `</div>`;
      }
    }

    if (lane === 'prep' && item.sample_content) {
      body += `<div class="modal-section"><h3>What's inside ${escapeHtml(item.display_name || item.name)}</h3>`;
      body += `<div class="sample-preview">${escapeHtml(item.sample_content)}</div></div>`;
    }
    if (lane === 'prep' && item.governing_rule_excerpt) {
      body += `<div class="modal-section"><h3>The rules Claude follows when touching this file</h3>`;
      body += `<p style="font-size:13px;color:var(--muted);margin-bottom:8px;">Claude reads these rules automatically anytime it opens this brief. Keeps it from quoting numbers it can't trace.</p>`;
      body += `<div class="sample-preview">${escapeHtml(item.governing_rule_excerpt)}</div></div>`;
    }
    if (lane === 'prep' && item.sources && item.sources.length) {
      const sourceNames = item.sources.map(sid => {
        const src = DATA.pantry.find(p => p.id === sid);
        return src ? src.tool : sid;
      });
      body += `<div class="modal-section"><h3>Pulls from</h3><p>${sourceNames.map(n => '<code>' + escapeHtml(n) + '</code>').join(' &nbsp;&middot;&nbsp; ')}</p></div>`;
    }

    if (lane === 'plate' && item.sample_output) {
      body += `<div class="modal-section"><h3>Sample output</h3>`;
      body += `<div class="sample-preview">${escapeHtml(item.sample_output)}</div></div>`;
    }
    if (lane === 'plate' && item.ideation_loop && item.ideation_loop.length) {
      body += `<div class="modal-section"><h3>How Claude builds this for you, step by step</h3>`;
      body += `<ol class="ideation-list">` + item.ideation_loop.map(s => `<li>${escapeHtml(s)}</li>`).join('') + `</ol></div>`;
    }
    if (lane === 'plate' && item.approval_gate) {
      body += `<div class="modal-section"><h3>Sign-off</h3><p>&#128274; ${escapeHtml(item.approval_friendly || item.approval_gate)}</p></div>`;
    }

    if (opps.length) {
      body += `<div class="modal-section"><h3>Quick wins on this card</h3>`;
      opps.forEach(o => {
        body += `<p><strong>${escapeHtml(o.title)}.</strong> ${escapeHtml(o.explanation || '')}</p>`;
      });
      body += `</div>`;
    }

    if (item.claude_code_recommendation) {
      const r = item.claude_code_recommendation;
      body += `<div class="modal-section"><h3>What we'd build for this</h3>`;
      body += `<p><strong>${escapeHtml(r.skill_to_write || r.feature || '')}</strong>${r.rationale ? ', ' + escapeHtml(r.rationale) : ''}</p>`;
      if (r.estimated_time_savings) body += `<p style="margin-top:8px;"><span class="stack-pill" style="background:var(--coral-soft);color:var(--coral);border-color:var(--coral-border);">Saves ${escapeHtml(r.estimated_time_savings)}</span></p>`;
      body += `</div>`;
    }

    document.getElementById('cm-body').innerHTML = body;

    document.querySelectorAll('.conn-tab').forEach(t => {
      t.addEventListener('click', () => {
        document.querySelectorAll('.conn-tab').forEach(x => x.classList.remove('active'));
        document.querySelectorAll('.conn-content').forEach(x => x.classList.remove('active'));
        t.classList.add('active');
        document.querySelector(`.conn-content[data-conn-content="${t.dataset.conn}"]`).classList.add('active');
      });
    });

    document.getElementById('card-modal').classList.add('visible');
  }

  function openRecipeModal(id) {
    const r = DATA.recipes.find(x => x.id === id);
    if (!r) return;
    document.getElementById('rm-title').textContent = r.headline || r.name;
    document.getElementById('rm-goal').textContent = r.goal;

    let body = '';

    if (r.manual_today) {
      body += `<div class="today-card"><div class="today-label">Today, manually</div>${escapeHtml(r.manual_today)}</div>`;
    }
    if (r.monday_difference) {
      body += `<div class="monday-card"><div class="monday-label">Next Monday, with this live</div>${escapeHtml(r.monday_difference)}</div>`;
    }

    if (r.claude_code_stack) {
      const cs = r.claude_code_stack;
      body += `<div class="modal-section"><h3>What Claude Code parts power this</h3>`;
      body += PRIMITIVE_KEY;
      body += `<div class="stack-pills">`;
      (cs.skills || []).forEach(s => body += `<span class="stack-pill skill">skill: ${escapeHtml(s)}</span>`);
      (cs.subagents || []).forEach(s => body += `<span class="stack-pill subagent">subagent: ${escapeHtml(s)}</span>`);
      (cs.hooks || []).forEach(s => body += `<span class="stack-pill hook">hook: ${escapeHtml(s)}</span>`);
      (cs.rules || []).forEach(s => body += `<span class="stack-pill rule">rule: ${escapeHtml(s)}</span>`);
      body += `</div></div>`;
    }

    if (r.walkthrough && r.walkthrough.length) {
      body += `<div class="modal-section"><h3>The chain (back-and-forth between agents)</h3>`;
      body += `<ol class="ideation-list">`;
      r.walkthrough.forEach(step => {
        body += `<li><span class="actor">${escapeHtml(step.actor)}</span> ${escapeHtml(step.action)}</li>`;
      });
      body += `</ol></div>`;
    }

    if (r.before_claude_code || r.after_claude_code) {
      body += `<div class="modal-section"><h3>Before vs After Claude Code</h3>`;
      body += `<div class="recipe-impact">`;
      body += `<div class="before"><strong>Before:</strong> ${escapeHtml(r.before_claude_code || '')}</div>`;
      body += `<div class="after"><strong>After:</strong> ${escapeHtml(r.after_claude_code || '')}</div>`;
      body += `</div></div>`;
    }

    document.getElementById('rm-body').innerHTML = body;
    document.getElementById('recipe-modal').classList.add('visible');
  }

  function closeAll() {
    document.querySelectorAll('.overlay').forEach(o => o.classList.remove('visible'));
  }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeAll(); });
</script>

</body>
</html>
