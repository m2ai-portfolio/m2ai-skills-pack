  "detection_patterns": {
    "file_globs": ["*.py", "*.ts", "*.js", "*.jsx", "*.tsx", "*.yaml", "*.yml", "*.json", "*.toml", "*.env", "*.env.*", "*.cfg", "*.ini"],
    "skip_dirs": ["node_modules", "venv", ".venv", "__pycache__", ".git", "dist", "build", ".next", "target", ".tox", "site-packages"],
    "sdk_imports": {
      "anthropic_python": "from anthropic|import anthropic",
      "anthropic_ts": "from ['\"]@anthropic-ai/sdk|require\\(['\"]@anthropic-ai/sdk",
      "openai_python": "from openai|import openai",
      "openai_ts": "from ['\"]openai|require\\(['\"]openai",
      "google_python": "import google\\.generativeai|from google\\.generativeai|genai\\.configure",
      "google_ts": "from ['\"]@google/generative-ai|require\\(['\"]@google/generative-ai",
      "litellm": "from litellm|import litellm|litellm\\.completion",
      "langchain": "from langchain|import langchain|ChatOpenAI|ChatAnthropic|ChatGoogleGenerativeAI",
      "ollama_python": "import ollama|from ollama|ollama\\.chat",
      "ollama_ts": "from ['\"]ollama|require\\(['\"]ollama"
    },
    "model_string_patterns": [
      "claude-opus-[0-9]",
      "claude-sonnet-[0-9]",
      "claude-haiku-[0-9]",
      "claude-[0-9]",
      "gpt-5[.0-9]",
      "gpt-4[o0-9.-]",
      "o[1-4]-",
      "gemini-[0-9]",
      "meta-llama/",
      "nvidia/",
      "mistralai/",
      "deepseek-ai/",
      "Qwen/"
    ],
    "config_key_patterns": ["model", "model_name", "model_id", "llm_model", "ai_model", "chat_model", "embedding_model"],
    "env_var_patterns": ["ANTHROPIC_API_KEY", "OPENAI_API_KEY", "GOOGLE_API_KEY", "GEMINI_API_KEY", "DEEPINFRA_API_KEY", "TOGETHER_API_KEY", "OPENROUTER_API_KEY", "OLLAMA_HOST"]
  },
